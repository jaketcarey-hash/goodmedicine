---
interface Link {
  href: string;
  title: string;
  description?: string;
}

interface Props {
  branch: 'money' | 'rights' | 'path' | 'self';
  heading?: string;
  links: Link[];
}

const { branch, heading = 'Where to next', links } = Astro.props;

const accent: Record<string, string> = {
  money: 'related--clay',
  rights: 'related--water',
  path: 'related--sage',
  self: 'related--berry',
};
---

<nav class="related" aria-label={heading}>
  <p class="related__heading">{heading}</p>
  <div class="related__list">
    {links.map((link) => (
      <a href={link.href} class={`related__card ${accent[branch]}`}>
        <span class="related__text">
          <span class="related__title">{link.title}</span>
          {link.description && <span class="related__desc">{link.description}</span>}
        </span>
        <svg class="related__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
      </a>
    ))}
  </div>
</nav>

<style>
  .related {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-stone-100);
  }

  .related__heading {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-stone-400);
    margin-bottom: 0.75rem;
  }

  .related__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related__card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: var(--color-surface-card);
    border: 1px solid var(--color-stone-200);
    border-left-width: 3px;
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    color: inherit;
  }

  .related__card:hover {
    border-color: var(--color-stone-300);
    box-shadow: 0 1px 2px rgba(35, 30, 23, 0.06);
  }

  .related__card:active {
    transform: scale(0.98);
  }

  .related--clay  { border-left-color: var(--color-clay-400); }
  .related--water { border-left-color: var(--color-water-400); }
  .related--sage  { border-left-color: var(--color-sage-400); }
  .related--berry { border-left-color: var(--color-berry-400); }

  .related__text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .related__title {
    font-weight: 600;
    font-size: var(--text-sm);
    line-height: 1.3;
  }

  .related__desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .related__arrow {
    width: 1rem;
    height: 1rem;
    color: var(--color-stone-300);
    flex-shrink: 0;
    transition: color 250ms;
  }

  .related__card:hover .related__arrow {
    color: var(--color-stone-500);
  }
</style>
