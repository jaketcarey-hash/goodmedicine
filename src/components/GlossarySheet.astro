---
/**
 * GlossarySheet — inline term definitions for the whole site.
 *
 * Include once in Shell.astro. Scans every <strong> tag inside
 * #main-content on load; any whose text matches a glossary term gets a
 * dotted underline and tap-to-open behaviour. A single bottom sheet
 * handles all terms — no per-article changes needed.
 *
 * Matching handles common aliases:
 *   "Tax-Free Savings Account (TFSA)" → also matches bare "TFSA"
 *   "NIHB (Non-Insured Health Benefits)" → also matches bare "NIHB"
 *   Trailing colons and punctuation are stripped before comparison.
 */
import { GLOSSARY } from '../lib/glossary-data';

type SheetEntry = { term: string; definition: string; articleLink?: string };
const glossMap: Record<string, SheetEntry> = {};

function addKey(k: string, data: SheetEntry) {
  const key = k.toLowerCase().trim();
  if (key && !glossMap[key]) glossMap[key] = data;
}

for (const entry of GLOSSARY) {
  const data: SheetEntry = {
    term: entry.term,
    definition: entry.definition,
    articleLink: entry.articleLink,
  };

  addKey(entry.term, data);

  // "ACRONYM (Full Name)" → also register the bare acronym
  const acFirst = entry.term.match(/^([A-Z][A-Z0-9/]+(?:\s+[A-Z0-9]+)*)\s+\(/);
  if (acFirst) addKey(acFirst[1], data);

  // "Full Name (ACRONYM)" → also register bare acronym and bare name
  const acLast = entry.term.match(/^(.+)\s+\(([A-Z][A-Z0-9/]+)\)$/);
  if (acLast) {
    addKey(acLast[2], data);           // acronym: "CCB"
    addKey(acLast[1], data);           // bare name: "Canada Child Benefit"
  }
}

const glossMapJson = JSON.stringify(glossMap);
---

<!-- Bottom sheet + backdrop, hidden by default -->
<div
  id="gloss-backdrop"
  aria-hidden="true"
></div>

<div
  id="gloss-sheet"
  role="dialog"
  aria-modal="true"
  aria-labelledby="gloss-term"
  tabindex="-1"
>
  <!-- Drag handle (visual affordance) -->
  <div class="gloss-handle" aria-hidden="true"></div>

  <!-- Header row -->
  <div class="gloss-header">
    <p id="gloss-term" class="gloss-term-name"></p>
    <button id="gloss-close" aria-label="Close definition" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Definition -->
  <p id="gloss-def" class="gloss-def"></p>

  <!-- Deep-dive link (conditional) -->
  <a id="gloss-link" href="#" class="gloss-link">
    <span id="gloss-link-text">Read the full guide</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M13 5l7 7-7 7" />
    </svg>
  </a>
</div>

<style>
  #gloss-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 60;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  #gloss-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  #gloss-sheet {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 70;
    background: #faf8f5;
    border-radius: 1.25rem 1.25rem 0 0;
    padding: 0.75rem 1.25rem 2.5rem;
    box-shadow: 0 -4px 32px rgba(0, 0, 0, 0.12);
    max-height: 72vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;

    /* start off-screen */
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    /* respect iOS safe area at bottom */
    padding-bottom: calc(2.5rem + env(safe-area-inset-bottom, 0px));
  }
  #gloss-sheet.open {
    transform: translateY(0);
  }

  .gloss-handle {
    width: 2.5rem;
    height: 4px;
    background: #d6d3cf;
    border-radius: 9999px;
    margin: 0 auto 1rem;
  }

  .gloss-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .gloss-term-name {
    font-family: var(--font-display, sans-serif);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-primary, #1c1917);
    flex: 1;
    margin: 0;
  }

  #gloss-close {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: none;
    background: #e7e5e4;
    color: #78716c;
    cursor: pointer;
    transition: background 0.15s;
    margin-top: 0.1rem;
    padding: 0;
  }
  #gloss-close:hover {
    background: #d6d3ce;
  }

  .gloss-def {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary, #44403c);
    margin: 0 0 1.25rem;
  }

  .gloss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-water-600, #0369a1);
    text-decoration: none;
    transition: color 0.15s;
  }
  .gloss-link:hover {
    color: var(--color-water-700, #075985);
  }

  /* The dotted-underline marker on matched <strong> tags */
  :global(strong[data-gloss]) {
    cursor: pointer;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-color: currentColor;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  :global(strong[data-gloss]:focus-visible) {
    outline: 2px solid var(--color-water-500, #0284c7);
    outline-offset: 2px;
    border-radius: 2px;
  }
</style>

<script define:vars={{ glossMapJson }}>
  (function () {
    const GLOSS = JSON.parse(glossMapJson);

    function normalize(text) {
      return text
        .toLowerCase()
        .trim()
        .replace(/\s+/g, ' ')
        .replace(/[:’‘']+$/, '') // strip trailing colon or apostrophe
        .trim();
    }

    function lookup(text) {
      return GLOSS[normalize(text)] || null;
    }

    // ── Sheet elements ──────────────────────────────────────────────
    var backdrop = document.getElementById('gloss-backdrop');
    var sheet    = document.getElementById('gloss-sheet');
    var termEl   = document.getElementById('gloss-term');
    var defEl    = document.getElementById('gloss-def');
    var linkEl   = document.getElementById('gloss-link');
    var linkText = document.getElementById('gloss-link-text');
    var closeBtn = document.getElementById('gloss-close');

    if (!backdrop || !sheet) return;

    function openSheet(entry) {
      termEl.textContent = entry.term;
      defEl.textContent  = entry.definition;

      if (entry.articleLink) {
        linkEl.href = entry.articleLink;
        linkText.textContent = 'Read the full guide';
        linkEl.style.display = '';
      } else {
        linkEl.href = '/glossary';
        linkText.textContent = 'Browse the glossary';
        linkEl.style.display = '';
      }

      backdrop.style.display = '';
      sheet.style.display    = '';
      requestAnimationFrame(function () {
        backdrop.classList.add('open');
        sheet.classList.add('open');
        sheet.focus();
      });
    }

    function closeSheet() {
      backdrop.classList.remove('open');
      sheet.classList.remove('open');
      sheet.addEventListener(
        'transitionend',
        function () {
          backdrop.style.display = 'none';
          sheet.style.display    = 'none';
        },
        { once: true }
      );
    }

    // ── Wire up matching <strong> elements ──────────────────────────
    function scanStrongs() {
      var main = document.getElementById('main-content');
      if (!main) return;
      var strongs = main.querySelectorAll('strong');
      strongs.forEach(function (el) {
        if (el.hasAttribute('data-gloss')) return; // already wired
        var match = lookup(el.textContent || '');
        if (!match) return;

        el.setAttribute('data-gloss', '');
        el.setAttribute('role', 'button');
        el.setAttribute('tabindex', '0');
        el.setAttribute('aria-label', 'Definition: ' + el.textContent);

        el.addEventListener('click', function (e) {
          e.stopPropagation();
          openSheet(match);
        });
        el.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openSheet(match);
          }
        });
      });
    }

    // ── Close handlers ──────────────────────────────────────────────
    closeBtn.addEventListener('click', closeSheet);
    backdrop.addEventListener('click', closeSheet);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && sheet.classList.contains('open')) closeSheet();
    });

    // ── Initial scan + observe for Svelte-rendered content ──────────
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scanStrongs);
    } else {
      scanStrongs();
    }

    // Catch any content hydrated after initial load (Svelte islands)
    if (typeof MutationObserver !== 'undefined') {
      var observer = new MutationObserver(function () {
        scanStrongs();
      });
      var main = document.getElementById('main-content');
      if (main) observer.observe(main, { childList: true, subtree: true });
    }
  })();
</script>
