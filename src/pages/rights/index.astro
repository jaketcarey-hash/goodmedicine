---
import Shell from '../../layouts/Shell.astro';
import PageHeader from '../../components/PageHeader.svelte';
import TopicCard from '../../components/TopicCard.svelte';
---

<Shell title="Knowing Your Rights" branch="rights">
  <PageHeader
    title="Knowing Your Rights"
    subtitle="Your rights are powerful tools. Understanding them puts you in control."
    branch="rights"
    backHref="/"
    backLabel="Home"
  />

  <!-- Interactive tools -->
  <section class="px-5 pb-6">
    <h2 class="text-xs font-semibold text-stone-400 tracking-widest uppercase mb-3">Tools</h2>
    <div class="flex flex-col gap-2.5">
      <a href="/rights/section-87-checker" class="group flex items-center gap-3 rounded-xl bg-gradient-to-r from-water-50 to-water-100 border border-water-200 hover:border-water-300 p-4 transition-all duration-[var(--duration-normal)] active:scale-[0.98]">
        <div class="w-10 h-10 rounded-lg bg-water-500 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-sm">Section 87 Checker</p>
          <p class="text-xs text-text-muted">Find out if your income is likely tax-exempt</p>
        </div>
      </a>
      <a href="/self/benefits" class="group flex items-center gap-3 rounded-xl bg-gradient-to-r from-sage-50 to-water-50 border border-stone-200 hover:border-water-300 p-4 transition-all duration-[var(--duration-normal)] active:scale-[0.98]">
        <div class="w-10 h-10 rounded-lg bg-sage-500 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-sm">Benefits Finder</p>
          <p class="text-xs text-text-muted">Discover every benefit you might be entitled to</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Articles -->
  <section class="px-5 pb-10">
    <h2 class="text-xs font-semibold text-stone-400 tracking-widest uppercase mb-3">Learn</h2>
    <div class="flex flex-col gap-2.5">
      <TopicCard
        client:idle
        href="/rights/section-87"
        title="Section 87 Tax Exemption"
        description="What's exempt, what's not, and how to make sure you're not paying taxes you don't owe."
        branch="rights"
        readTime="8 min"
      />

      <TopicCard
        client:idle
        href="/rights/nihb"
        title="Non-Insured Health Benefits"
        description="Dental, vision, prescriptions, medical travel — what NIHB covers and how to make sure you're using it."
        branch="rights"
        readTime="6 min"
      />

      <TopicCard
        client:idle
        href="/rights/treaty-payments"
        title="Treaty Payments"
        description="What treaty payments are, how modern treaties work, and what resource revenue sharing means for you."
        branch="rights"
        readTime="7 min"
      />

      <TopicCard
        client:idle
        href="/rights/education-funding"
        title="Education Funding"
        description="Band funding, PSSSP, Indspire, provincial programs — how to pay for post-secondary and what to know."
        branch="rights"
        readTime="9 min"
      />

      <TopicCard
        client:idle
        href="/rights/band-finances"
        title="Band Finances and Trusts"
        description="How band trusts work, per-capita distributions, and your right to financial transparency."
        branch="rights"
        readTime="10 min"
      />

      <TopicCard
        client:idle
        href="/rights/jordans-principle"
        title="Jordan's Principle"
        description="Services for First Nations children — what's covered, how to apply, and how to appeal if denied."
        branch="rights"
        readTime="8 min"
      />
    </div>
  </section>
</Shell>
