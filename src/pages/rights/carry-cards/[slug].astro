---
import Shell from '../../../layouts/Shell.astro';
import { CARRY_CARDS, getCarryCard, accentBar } from '../../../lib/carry-cards-data';

export function getStaticPaths() {
  return CARRY_CARDS.filter((c) => c.published).map((c) => ({
    params: { slug: c.slug },
  }));
}

const { slug } = Astro.params;
const card = getCarryCard(slug!);

if (!card || !card.published) {
  return Astro.redirect('/rights/carry-cards');
}

const barColor = accentBar(card.accent);
---

<Shell title={card.title} branch="rights">
  <article class="px-5 pt-10 pb-12">
    <!-- Back link -->
    <a
      href="/rights/carry-cards"
      class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-stone-700 transition-colors mb-6"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
      Carry Cards
    </a>

    <!-- The front: setting + the one-line answer -->
    <div
      class="rounded-2xl bg-surface-card border border-stone-200 p-6 shadow-sm"
      style={`border-left: 4px solid ${barColor};`}
    >
      <p class="text-[11px] font-semibold tracking-widest uppercase text-text-muted">{card.setting}</p>
      <h1 class="text-2xl font-bold tracking-tight leading-snug mt-2">{card.title}</h1>
      <p class="text-lg text-text-primary leading-relaxed mt-3">{card.answer}</p>
    </div>

    <!-- Bring -->
    {card.bring && card.bring.length > 0 && (
      <section class="mt-9">
        <h2 class="carry-heading">Bring</h2>
        <ul class="mt-3 space-y-2">
          {card.bring.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="18" rx="2" /><path d="M9 8h6M9 12h6M9 16h4" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Say -->
    {card.say && card.say.length > 0 && (
      <section class="mt-9">
        <h2 class="carry-heading">What to say</h2>
        <div class="mt-3 space-y-3">
          {card.say.map((s) => (
            <div class="rounded-xl border border-stone-200 bg-surface-card p-4">
              {s.when && (
                <p class="text-[11px] font-semibold tracking-widest uppercase text-text-muted mb-1.5">{s.when}</p>
              )}
              <p class="text-sm text-text-secondary leading-relaxed italic">“{s.line}”</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Your rights -->
    {card.rights && card.rights.length > 0 && (
      <section class="mt-9">
        <h2 class="carry-heading">What's yours by right</h2>
        <ul class="mt-3 space-y-2.5">
          {card.rights.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-sage-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Watch for -->
    {card.watchFor && card.watchFor.length > 0 && (
      <section class="mt-9">
        <h2 class="carry-heading">Watch for</h2>
        <div class="mt-3 space-y-2.5">
          {card.watchFor.map((item) => (
            <div class="rounded-xl bg-clay-50 border-l-[3px] border-clay-400 px-4 py-3">
              <p class="text-sm text-stone-700 leading-relaxed m-0">{item}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Calls -->
    {card.calls && card.calls.length > 0 && (
      <section class="mt-9">
        <h2 class="carry-heading">Call</h2>
        <div class="mt-3 space-y-2.5">
          {card.calls.map((c) => (
            <a
              href={c.numberHref}
              class="flex items-center justify-between gap-3 rounded-xl border border-stone-200 bg-surface-card p-4 transition-colors hover:border-water-300 active:scale-[0.99]"
            >
              <div class="flex items-center gap-3 min-w-0">
                <svg class="w-4 h-4 flex-shrink-0 text-water-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z" />
                </svg>
                <span class="font-semibold text-sm truncate">{c.label}</span>
              </div>
              <span class="text-sm font-mono text-water-600 flex-shrink-0">{c.number}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Source / go deeper -->
    <section class="mt-12 pt-6 border-t border-stone-100">
      <a
        href={card.sourceHref}
        class="inline-flex items-center gap-1.5 text-sm text-water-600 hover:text-water-700 transition-colors font-medium"
      >
        Read the full guide: {card.sourceLabel}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <p class="text-xs text-text-muted mt-3 leading-relaxed">
        This card is a plain-language summary, not advice. The full guide has the detail and the
        caveats — read it when you have a moment that isn't this one.
      </p>
    </section>
  </article>
</Shell>

<style>
  .carry-heading {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
</style>
