---
import Shell from '../../layouts/Shell.astro';
import PageHeader from '../../components/PageHeader.svelte';
import Section87Checker from '../../components/Section87Checker.svelte';
---

<Shell title="Section 87 Checker" branch="rights">
  <PageHeader
    title="Section 87 Checker"
    subtitle="Walk through the connecting factors test to see if your employment income may be tax-exempt."
    branch="rights"
    backHref="/rights"
    backLabel="Rights"
  />

  <div class="px-5 pb-12">
    <p class="text-sm text-text-secondary mb-6 leading-relaxed max-w-md">
      Section 87 of the Indian Act exempts certain income of Status Indians from taxation
      when that income is "situated on a reserve." The courts use a connecting factors test
      from <em>Williams v. Canada</em> to determine this. Answer a few questions to see where
      you likely stand.
    </p>

    <Section87Checker client:load />

    <div class="mt-8 pt-6 border-t border-stone-200">
      <a
        href="/rights/section-87"
        class="group flex items-center gap-3 rounded-xl bg-surface-card border border-stone-200 hover:border-water-300 p-4 transition-all duration-[var(--duration-normal)]"
      >
        <div class="w-9 h-9 rounded-lg bg-water-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-4.5 h-4.5 text-water-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" />
            <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="font-medium text-sm">Section 87 Full Guide</p>
          <p class="text-xs text-text-muted">Employment income, investments, government benefits, and practical steps</p>
        </div>
      </a>
    </div>
  </div>
</Shell>
