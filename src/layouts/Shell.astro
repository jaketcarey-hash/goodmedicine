---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.svelte';
import OfflineBanner from '../components/OfflineBanner.svelte';
import GlossarySheet from '../components/GlossarySheet.astro';

interface Props {
  title?: string;
  description?: string;
  branch?: 'money' | 'rights' | 'path' | 'self' | 'home' | 'moments';
}

const {
  title = 'Strong Fire',
  description = 'Free financial wellness for First Nations communities',
  branch = 'home',
} = Astro.props;

const fullTitle = title === 'Strong Fire' ? title : `${title} — Strong Fire`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf8f5" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <title>{fullTitle}</title>

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>

  <body class="bg-surface text-text-primary pb-[var(--nav-height)]" data-branch={branch}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-stone-900 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm">
      Skip to content
    </a>
    <OfflineBanner client:load />
    <main
      class="mx-auto max-w-lg min-h-[calc(100dvh-var(--nav-height))]"
      id="main-content"
    >
      <slot />
    </main>

    <BottomNav client:load activeBranch={branch} />
    <GlossarySheet />

    <!-- Breadcrumb: save last visited page -->
    <script is:inline>
      (function() {
        try {
          var path = window.location.pathname;
          var skip = ['/', '/settings'];
          if (skip.indexOf(path) === -1) {
            var titleEl = document.querySelector('title');
            var pageTitle = titleEl ? titleEl.textContent.replace(/ — Strong Fire$/, '') : path;
            var data = JSON.stringify({ path: path, title: pageTitle, timestamp: new Date().toISOString() });
            localStorage.setItem('gm_last_visited', data);
          }
        } catch(e) {}
      })();
    </script>

    <!-- Service worker registration + global error handling -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
      window.addEventListener('error', function(e) {
        if (e.message && e.message.includes('ResizeObserver')) return;
        console.error('Strong Fire error:', e.message);
      });
      window.addEventListener('unhandledrejection', function(e) {
        console.error('Strong Fire error:', e.reason);
      });
    </script>
  </body>
</html>
